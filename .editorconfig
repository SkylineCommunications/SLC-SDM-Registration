root = true

[*]
indent_style = tab
indent_size = 4
tab_width = 4
end_of_line = crlf
trim_trailing_whitespace = true
vsspell_ignored_words = File:allowed_words.dic

[*.cs]
dotnet_sort_system_directives_first = true

# Code analysis rules from qaction-debug.ruleset
dotnet_diagnostic.CS1587.severity = none
dotnet_diagnostic.CS1591.severity = none
dotnet_diagnostic.S100.severity = warning
dotnet_diagnostic.S1006.severity = warning
dotnet_diagnostic.S101.severity = warning
